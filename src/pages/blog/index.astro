---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => data.status === 'published');
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const categories = [
  { slug: 'linkedin-strategy', label: 'LinkedIn Strategy' },
  { slug: 'content-systems', label: 'Content Systems' },
  { slug: 'brand-building', label: 'Brand Building' },
  { slug: 'growth-marketing', label: 'Growth Marketing' },
  { slug: 'case-studies', label: 'Case Studies' },
];
---

<BaseLayout
  title="Blog | Ahmad Farooq"
  description="No fluff. No generic advice. Just clear thinking on LinkedIn, content systems, and building a personal brand that works."
  canonicalPath="/blog"
>
  <Header />

  <main>

    <section class="page-hero" aria-label="Page introduction">
      <div class="page-hero-inner">
        <span class="page-hero-label">The Blog</span>
        <h1 class="page-hero-title">Ideas that actually help you grow.</h1>
        <p class="page-hero-desc">No fluff. No generic advice. Just clear thinking on LinkedIn, content systems, and building a personal brand that works.</p>
      </div>
    </section>

    <!-- FEATURED POST -->
    <section class="section" style="border-bottom: 2px solid var(--border);" aria-label="Featured post">
      <div class="container">
        <a class="featured-post reveal" href="/blog/why-your-linkedin-is-not-getting-you-clients">
          <span class="featured-post-label">Start Here</span>
          <h2 class="featured-post-title">Why Your LinkedIn Is Not Getting You Clients (And It Has Nothing To Do With How Often You Post)</h2>
          <p class="featured-post-desc">Almost every struggling LinkedIn profile has the same three problems underneath. None of them are fixed by posting more. This piece breaks down all three and shows you exactly what to do instead.</p>
          <span class="featured-post-meta">8 minute read</span>
          <span class="featured-post-cta">Read the Article &rarr;</span>
        </a>
      </div>
    </section>

    <section class="section" aria-label="Blog posts">
      <div class="container">

        <div class="filter-bar" role="group" aria-label="Filter posts by category">
          <button class="filter-btn active" data-category="all">All</button>
          {categories.map(cat => (
            <button class="filter-btn" data-category={cat.slug}>{cat.label}</button>
          ))}
        </div>

        {posts.length === 0 ? (
          <p class="blog-empty">No posts yet. Check back soon.</p>
        ) : (
          <div class="blog-grid" id="blog-grid">
            {posts.map(post => {
              const slug = post.data.slug || post.slug;
              return (
                <a class="blog-card reveal" href={`/blog/${slug}`} data-category={post.data.category}>
                  {post.data.imageUrl && (
                    <img class="blog-card-thumb" src={post.data.imageUrl} alt={post.data.title}>
                  )}
                  <div class="blog-card-content">
                    <div style="margin-bottom:10px;">
                      <span class="tag tag-ghost">{post.data.category.replace(/-/g, ' ')}</span>
                    </div>
                    <h3>{post.data.title}</h3>
                    <p>{post.data.excerpt}</p>
                  </div>
                  <div class="blog-card-meta">
                    <span class="blog-card-date">{post.data.date.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' })}</span>
                    {post.data.readTime && <span class="blog-card-readtime">{post.data.readTime}</span>}
                  </div>
                </a>
              );
            })}
          </div>
        )}

      </div>
    </section>

    <!-- Email Signup -->
    <section class="section" style="border-top: 2px solid var(--border);" aria-label="Email signup">
      <div class="container" style="max-width: 720px;">
        <div class="section-header reveal" style="margin-bottom: 32px;">
          <span class="section-label">The List</span>
          <h2>Get new articles before anyone else.</h2>
          <p style="margin-top: 12px; color: var(--text-muted);">New pieces go to the email list first. No spam. Just useful thinking on building a personal brand that compounds.</p>
        </div>
        <div class="reveal">
          <iframe data-tally-src="https://tally.so/embed/xXakVv?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1" loading="lazy" width="100%" height="216" frameborder="0" marginheight="0" marginwidth="0" title="Newsletter signup"></iframe>
          <script>var d=document,w="https://tally.so/widgets/embed.js",v=function(){"undefined"!=typeof Tally?Tally.loadEmbeds():d.querySelectorAll("iframe[data-tally-src]:not([src])").forEach((function(e){e.src=e.dataset.tallySrc}))};if("undefined"!=typeof Tally)v();else if(d.querySelector('script[src="'+w+'"]')==null){var s=d.createElement("script");s.src=w,s.onload=v,s.onerror=v,d.body.appendChild(s);}</script>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>
