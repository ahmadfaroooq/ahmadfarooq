---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ServicePage from '../components/ServicePage.astro';
import data from '../content/pages/growth.json';
---

<BaseLayout
  title="Growth Marketing | Ahmad Farooq"
  description="Growth is not a campaign. I help founders and businesses build marketing systems that compound over time — not spike once and disappear."
  canonicalPath="/growth"
>
  <Header />
  <main>
    <ServicePage data={data} />
  </main>
  <Footer />
</BaseLayout>
