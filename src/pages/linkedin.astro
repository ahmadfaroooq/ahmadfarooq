---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ServicePage from '../components/ServicePage.astro';
import data from '../content/pages/linkedin.json';
---

<BaseLayout
  title="LinkedIn Branding | Ahmad Farooq"
  description="Turn your LinkedIn into an inbound machine. I help coaches, consultants, and founders build a LinkedIn presence that attracts the right people and moves them toward a conversation."
  canonicalPath="/linkedin"
>
  <Header />
  <main>
    <ServicePage data={data} />
  </main>
  <Footer />
</BaseLayout>
