---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Are We a Fit? | Ahmad Farooq"
  description="Answer 5 quick questions and find out if working together makes sense — before you book a call."
  canonicalPath="/qualify"
>
  <Header />

  <main>

    <section class="page-hero">
      <div class="page-hero-inner">
        <span class="page-hero-label">Quick Qualifier</span>
        <h1 class="page-hero-title">Are We a Good Fit?</h1>
        <p class="page-hero-desc">5 questions. 60 seconds. Find out if working together makes sense — before either of us spends time on a call.</p>
      </div>
    </section>

    <section class="section">
      <div class="container" style="max-width: 680px;">

        <!-- FORM -->
        <form id="qualify-form" style="display:flex;flex-direction:column;gap:28px;">

          <div class="qualify-field">
            <label class="qualify-label" for="q-name">Your name</label>
            <input class="qualify-input" id="q-name" name="name" type="text" placeholder="Jane Smith" required>
          </div>

          <div class="qualify-field">
            <label class="qualify-label" for="q-role">Your role / title</label>
            <input class="qualify-input" id="q-role" name="role" type="text" placeholder="Founder, CMO, Head of Growth...">
          </div>

          <div class="qualify-field">
            <label class="qualify-label">What's your primary goal?</label>
            <div class="qualify-options" id="q-goal">
              <button type="button" class="qualify-opt" data-group="goal" data-value="Build my personal brand on LinkedIn">Build my LinkedIn personal brand</button>
              <button type="button" class="qualify-opt" data-group="goal" data-value="Growth marketing strategy and execution">Growth marketing strategy</button>
              <button type="button" class="qualify-opt" data-group="goal" data-value="Brand identity and positioning">Brand identity & positioning</button>
              <button type="button" class="qualify-opt" data-group="goal" data-value="Copy writing and content strategy">Copy writing & content</button>
            </div>
            <input type="hidden" name="goal" id="goal-val" required>
          </div>

          <div class="qualify-field">
            <label class="qualify-label">Where is your business right now?</label>
            <div class="qualify-options" id="q-stage">
              <button type="button" class="qualify-opt" data-group="stage" data-value="Pre-revenue / early stage">Pre-revenue / early stage</button>
              <button type="button" class="qualify-opt" data-group="stage" data-value="$0 - $250K ARR">$0 – $250K ARR</button>
              <button type="button" class="qualify-opt" data-group="stage" data-value="$250K - $1M ARR">$250K – $1M ARR</button>
              <button type="button" class="qualify-opt" data-group="stage" data-value="$1M+ ARR or funded">$1M+ ARR or funded</button>
            </div>
            <input type="hidden" name="stage" id="stage-val" required>
          </div>

          <div class="qualify-field">
            <label class="qualify-label">Monthly budget for this?</label>
            <div class="qualify-options" id="q-budget">
              <button type="button" class="qualify-opt" data-group="budget" data-value="Under $500/month">Under $500/mo</button>
              <button type="button" class="qualify-opt" data-group="budget" data-value="$500 - $1500/month">$500 – $1,500/mo</button>
              <button type="button" class="qualify-opt" data-group="budget" data-value="$1500 - $3000/month">$1,500 – $3,000/mo</button>
              <button type="button" class="qualify-opt" data-group="budget" data-value="$3000+/month">$3,000+/mo</button>
            </div>
            <input type="hidden" name="budget" id="budget-val" required>
          </div>

          <div class="qualify-field">
            <label class="qualify-label" for="q-context">Anything else? <span style="color:var(--text-muted);font-weight:400">(optional)</span></label>
            <textarea class="qualify-input qualify-textarea" id="q-context" name="context" rows="3" placeholder="What's your biggest challenge right now, or what prompted this?"></textarea>
          </div>

          <button type="submit" class="btn btn-primary" id="qualify-submit" style="align-self:flex-start;">
            Check My Fit
            <svg viewBox="0 0 16 16" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 8h10M9 4l4 4-4 4"/></svg>
          </button>

        </form>

        <!-- LOADING STATE -->
        <div id="qualify-loading" style="display:none;text-align:center;padding:60px 0;">
          <div class="qualify-spinner"></div>
          <p style="margin-top:20px;color:var(--text-muted);font-family:var(--font-heading);font-size:0.9rem;">Evaluating your fit…</p>
        </div>

        <!-- RESULT -->
        <div id="qualify-result" style="display:none;">
          <div id="result-card" class="qualify-result-card">
            <div id="result-badge" class="qualify-result-badge"></div>
            <h2 id="result-headline" style="margin:20px 0 12px;"></h2>
            <p id="result-reasoning" style="color:var(--text-light);margin-bottom:24px;"></p>
            <div id="result-next" class="qualify-result-next"></div>
          </div>
          <button type="button" id="qualify-restart" class="btn btn-secondary" style="margin-top:24px;">Start over</button>
        </div>

      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>

<style>
.qualify-field { display: flex; flex-direction: column; gap: 10px; }
.qualify-label {
  font-family: var(--font-heading);
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--text);
}
.qualify-input {
  font-family: var(--font-body);
  font-size: 1rem;
  color: var(--text);
  background: var(--white);
  border: 2px solid var(--border);
  padding: 12px 16px;
  outline: none;
  width: 100%;
  transition: border-color 0.2s, box-shadow 0.2s;
}
.qualify-input:focus {
  border-color: var(--lime);
  box-shadow: 3px 3px 0 var(--lime);
}
.qualify-textarea { resize: vertical; min-height: 80px; }

.qualify-options { display: flex; flex-wrap: wrap; gap: 10px; }
.qualify-opt {
  font-family: var(--font-heading);
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--text);
  background: var(--white);
  border: 2px solid var(--border);
  padding: 10px 18px;
  cursor: pointer;
  transition: background 0.2s, color 0.2s, border-color 0.2s, transform 0.2s, box-shadow 0.2s;
}
.qualify-opt:hover { border-color: var(--lime); }
.qualify-opt.selected {
  background: var(--lime);
  color: var(--black);
  border-color: var(--lime);
  transform: translate(-2px, -2px);
  box-shadow: 3px 3px 0 var(--border);
}

/* Spinner */
.qualify-spinner {
  width: 40px; height: 40px;
  border: 3px solid rgba(0,0,0,0.1);
  border-top-color: var(--lime);
  border-radius: 50%;
  margin: 0 auto;
  animation: spin 0.8s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* Result card */
.qualify-result-card {
  border: 2px solid var(--border);
  padding: 40px;
  background: var(--white);
}
.qualify-result-badge {
  display: inline-block;
  padding: 6px 16px;
  font-family: var(--font-heading);
  font-size: 0.72rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.08em;
}
.badge-good    { background: var(--lime);   color: var(--black); }
.badge-maybe   { background: #FFE066;       color: var(--black); }
.badge-not     { background: var(--orange); color: var(--white); }

.qualify-result-next {
  background: var(--bg-dark);
  border: 2px solid var(--border);
  padding: 20px 24px;
  font-family: var(--font-heading);
  font-size: 0.95rem;
  font-weight: 600;
}
.qualify-result-next a {
  color: var(--orange);
  text-decoration: underline;
  text-underline-offset: 3px;
}
</style>

<script>
// Option picker
document.querySelectorAll('.qualify-opt').forEach(btn => {
  btn.addEventListener('click', () => {
    const group = btn.dataset.group;
    document.querySelectorAll(`.qualify-opt[data-group="${group}"]`).forEach(b => b.classList.remove('selected'));
    btn.classList.add('selected');
    document.getElementById(`${group}-val`).value = btn.dataset.value;
  });
});

// Form submit
document.getElementById('qualify-form').addEventListener('submit', async (e) => {
  e.preventDefault();
  const form = e.target;
  const data = Object.fromEntries(new FormData(form));

  // Validate options
  if (!data.goal || !data.stage || !data.budget) {
    alert('Please select an option for all required questions.');
    return;
  }

  form.style.display = 'none';
  document.getElementById('qualify-loading').style.display = 'block';

  try {
    const res = await fetch('/api/qualify', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(data),
    });
    const result = await res.json();

    document.getElementById('qualify-loading').style.display = 'none';
    document.getElementById('qualify-result').style.display = 'block';

    const badge = document.getElementById('result-badge');
    const fitMap = {
      'good':       { label: '✓ Good Fit',     cls: 'badge-good' },
      'maybe':      { label: '~ Possible Fit', cls: 'badge-maybe' },
      'not-a-fit':  { label: '✗ Not a Fit',    cls: 'badge-not' },
    };
    const fit = fitMap[result.fit] || fitMap['maybe'];
    badge.textContent = fit.label;
    badge.className = `qualify-result-badge ${fit.cls}`;

    document.getElementById('result-headline').textContent = result.headline || '';
    document.getElementById('result-reasoning').textContent = result.reasoning || '';

    const nextEl = document.getElementById('result-next');
    if (result.fit === 'good' || result.fit === 'maybe') {
      nextEl.innerHTML = `Next step: <a href="/book">Book a free 30-min strategy call →</a>`;
    } else {
      nextEl.textContent = result.nextStep || 'Check back when your business has grown — or explore the free Playbook.';
    }

  } catch (err) {
    document.getElementById('qualify-loading').style.display = 'none';
    form.style.display = 'flex';
    alert('Something went wrong. Please try again.');
  }
});

// Restart
document.getElementById('qualify-restart').addEventListener('click', () => {
  document.getElementById('qualify-result').style.display = 'none';
  document.getElementById('qualify-form').style.display = 'flex';
  document.querySelectorAll('.qualify-opt').forEach(b => b.classList.remove('selected'));
  ['goal-val','stage-val','budget-val'].forEach(id => {
    document.getElementById(id).value = '';
  });
});
</script>
