---
import settings from '../content/global/settings.json';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonicalPath?: string;
  type?: 'website' | 'article';
}

const {
  title,
  description,
  ogImage = '/images/ahmad-profile.png',
  canonicalPath = '',
  type = 'website',
} = Astro.props;

const siteUrl = 'https://ahmadfarooq.vercel.app';
const canonical = `${siteUrl}${canonicalPath}`;
const ogImageFull = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;

const FAVICON = `data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' fill='%23f36f21'/><rect x='2' y='2' width='96' height='96' fill='none' stroke='black' stroke-width='4'/><rect x='25' y='25' width='50' height='50' fill='%232ecc40' stroke='black' stroke-width='4' transform='rotate(45 50 50)'/><circle cx='50' cy='50' r='12' fill='black'/></svg>`;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>{title}</title>
  <meta name="description" content={description}>
  <meta name="robots" content="index, follow">
  <link rel="canonical" href={canonical}>

  <meta property="og:type" content={type}>
  <meta property="og:url" content={canonical}>
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content={ogImageFull}>
  <meta property="og:site_name" content="Ahmad Farooq">
  <meta property="og:locale" content="en_US">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:site" content={settings.twitterHandle}>
  <meta name="twitter:creator" content={settings.twitterHandle}>
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImageFull}>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "Ahmad Farooq",
    "jobTitle": "Growth Strategist & Brand Builder",
    "url": siteUrl,
    "email": settings.email,
    "sameAs": [settings.linkedinUrl, settings.twitterUrl],
  })} />

  <link rel="icon" type="image/svg+xml" href={FAVICON}>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=Caveat:wght@400;500;600;700&family=Playfair+Display:wght@400;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
  <Analytics />
</head>
<body class="page-transition">
  <slot />
  <script src="/scripts.js" is:inline></script>
</body>
</html>
