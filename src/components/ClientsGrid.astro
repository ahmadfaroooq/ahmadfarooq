---
import settings from '../content/global/settings.json';
---

<section class="section" aria-labelledby="clients-heading">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">Selected Clients</span>
      <h2 id="clients-heading">Brands I've built with.</h2>
    </div>
    <div class="clients-grid reveal">
      {settings.clients.map(client => (
        <div class="client-item">{client.name}</div>
      ))}
    </div>
  </div>
</section>
