---
import settings from '../content/global/settings.json';
const year = new Date().getFullYear();
---

<footer class="footer-minimal">
  <!-- Retro grid overlay -->
  <div class="footer-grid-overlay" aria-hidden="true"></div>
  <!-- Neon glow line -->
  <div class="footer-glow-line" aria-hidden="true"></div>

  <div class="footer-inner-wrap">

    <!-- Main 3-col grid -->
    <div class="footer-cols">

      <!-- Brand column -->
      <div class="footer-brand-col">
        <a href="/" class="footer-brand-link" aria-label="Ahmad Farooq">
          <svg width="32" height="32" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect width="100" height="100" fill="#f36f21"/>
            <rect x="2" y="2" width="96" height="96" fill="none" stroke="black" stroke-width="4"/>
            <rect x="25" y="25" width="50" height="50" fill="#2ecc40" stroke="black" stroke-width="4" transform="rotate(45 50 50)"/>
            <circle cx="50" cy="50" r="12" fill="black"/>
          </svg>
          <span class="footer-brand-name">Ahmad Farooq</span>
        </a>

        <p class="footer-tagline">
          Growth Strategist &amp; Brand Builder. Helping founders and executives build brands that compound over time.
        </p>

        <div class="footer-socials-row">
          <a href={settings.linkedinUrl} class="footer-social-btn" aria-label="LinkedIn" target="_blank" rel="noopener noreferrer">
            <!-- LinkedIn -->
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>
            </svg>
          </a>
          <a href={settings.twitterUrl} class="footer-social-btn" aria-label="Twitter / X" target="_blank" rel="noopener noreferrer">
            <!-- X / Twitter -->
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622L18.244 2.25Zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77Z"/>
            </svg>
          </a>
          <a href={`mailto:${settings.email}`} class="footer-social-btn" aria-label="Email">
            <!-- Mail -->
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Navigate column -->
      <div class="footer-nav-col">
        <span class="footer-col-label">Navigate</span>
        {settings.footerPages.map(link => (
          <a href={link.href} class="footer-nav-link">{link.label}</a>
        ))}
      </div>

      <!-- Services column -->
      <div class="footer-nav-col">
        <span class="footer-col-label">Services</span>
        {settings.footerServices.map(link => (
          <a href={link.href} class="footer-nav-link">{link.label}</a>
        ))}
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="footer-bottom-bar">
      <p class="footer-copy">© {year} Ahmad Farooq. All rights reserved.</p>
      <a href={`mailto:${settings.email}`} class="footer-email-link">{settings.email}</a>
    </div>

  </div>
</footer>
