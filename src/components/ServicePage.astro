---
import CTABand from './CTABand.astro';

interface MainItem {
  num: string;
  title: string;
  body: string;
}

interface Props {
  data: {
    heroLabel: string;
    heroTitle: string;
    heroDesc: string;
    problemHeading: string;
    problemBody: string;
    mainLabel: string;
    mainHeading: string;
    mainItems?: MainItem[];
    mainBody?: string;
    deliverablesLabel?: string;
    deliverablesHeading?: string;
    deliverables?: string[];
    resultsHeading?: string;
    results?: string[];
    ctaHeadline: string;
    ctaSubtext: string;
  };
}

const { data } = Astro.props;
---

<section class="page-hero" aria-label="Page introduction">
  <div class="page-hero-inner">
    <span class="page-hero-label">{data.heroLabel}</span>
    <h1 class="page-hero-title">{data.heroTitle}</h1>
    <p class="page-hero-desc">{data.heroDesc}</p>
  </div>
</section>

<section class="section" aria-labelledby="problem-heading">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">The Problem</span>
      <h2 id="problem-heading">{data.problemHeading}</h2>
    </div>
    <div class="prose reveal">
      {data.problemBody.split('\n\n').map((p: string) => <p>{p}</p>)}
    </div>
  </div>
</section>

<section class="section" style="background: var(--bg-dark); border-top: 2px solid var(--border); border-bottom: 2px solid var(--border);" aria-labelledby="main-heading">
  <div class="container">
    <div class="section-header reveal">
      <span class="section-label">{data.mainLabel}</span>
      <h2 id="main-heading">{data.mainHeading}</h2>
    </div>

    {data.mainBody && (
      <div class="prose reveal">
        {data.mainBody.split('\n\n').map((p: string) => <p>{p}</p>)}
      </div>
    )}

    {data.mainItems && (
      <ol class="timeline" role="list">
        {data.mainItems.map((item: MainItem) => (
          <li class="timeline-step reveal">
            <div class="timeline-dot" aria-hidden="true"></div>
            <span class="timeline-step-num">{item.num}</span>
            <h4>{item.title}</h4>
            <p>{item.body}</p>
          </li>
        ))}
      </ol>
    )}
  </div>
</section>

{data.deliverables && (
  <section class="section" aria-labelledby="deliverables-heading">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-label">{data.deliverablesLabel || 'What You Get'}</span>
        <h2 id="deliverables-heading">{data.deliverablesHeading}</h2>
      </div>
      <ul class="deliverables-list reveal" role="list">
        {data.deliverables.map((item: string) => (
          <li class="deliverable-item">{item}</li>
        ))}
      </ul>
    </div>
  </section>
)}

{data.results && (
  <section class="section" aria-labelledby="results-heading">
    <div class="container">
      <div class="section-header reveal">
        <span class="section-label">Results</span>
        <h2 id="results-heading">{data.resultsHeading}</h2>
      </div>
      <ul class="results-list reveal" role="list">
        {data.results.map((r: string) => (
          <li class="result-item">{r}</li>
        ))}
      </ul>
    </div>
  </section>
)}

<CTABand heading={data.ctaHeadline} subtext={data.ctaSubtext} btnText="Book a Free Strategy Call" />
